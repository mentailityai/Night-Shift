# =============================================================================
# Night-Shift Preference Optimizer — Environment Configuration Template
# =============================================================================
# Copy this file to .env and populate with your actual values.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=nightshift
POSTGRES_PASSWORD=nightshift
POSTGRES_DB=nightshift
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full connection string (auto-composed from the above if left blank)
# DATABASE_URL=postgresql+asyncpg://nightshift:nightshift@localhost:5432/nightshift

# -----------------------------------------------------------------------------
# Redis (Celery Broker)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Supported providers: "vllm", "openai", "anthropic"
LLM_PROVIDER=vllm

# --- vLLM (local) ---
VLLM_BASE_URL=http://your-vllm-host:8000/v1
VLLM_MODEL_NAME=your-model-name
VLLM_API_KEY=token-placeholder

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_NAME=gpt-4o

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL_NAME=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
# The model used to generate vector embeddings for rule semantic search.
# Default: BAAI/bge-m3 (1024-dim, runs locally via sentence-transformers)
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# -----------------------------------------------------------------------------
# Night-Shift Worker
# -----------------------------------------------------------------------------
# Cron schedule for the nightly processing run (Celery beat crontab format).
WORKER_CRON_MINUTE=0
WORKER_CRON_HOUR=2

# Batch-size trigger: if the number of 'pending' logs reaches this count,
# a processing run is fired immediately (in addition to the cron schedule).
WORKER_BATCH_TRIGGER_SIZE=50

# Maximum number of logs to process in a single worker run.
WORKER_BATCH_PROCESS_LIMIT=100

# -----------------------------------------------------------------------------
# Fine-Tuning (Slow Loop)
# -----------------------------------------------------------------------------
# Number of 'waiting' rows in Fine_Tuning_Staging required to trigger export.
FINE_TUNING_THRESHOLD=500

# Directory where exported .jsonl files are written.
FINE_TUNING_EXPORT_DIR=./exports

# Future: set to "openai" or "vllm" to trigger real fine-tune API calls.
FINE_TUNING_PROVIDER=local

# --- OpenAI Fine-Tuning (when FINE_TUNING_PROVIDER=openai) ---
# OPENAI_FINETUNE_MODEL=gpt-4o-mini-2024-07-18

# --- vLLM Fine-Tuning (when FINE_TUNING_PROVIDER=vllm) ---
# VLLM_FINETUNE_BASE_URL=http://your-vllm-host:8000

# Percentage of older high-quality data mixed into each fine-tuning batch
# to prevent catastrophic forgetting.  Value is a float 0.0 – 1.0.
FINE_TUNING_REPLAY_BUFFER_RATIO=0.15

# -----------------------------------------------------------------------------
# MCP Server (Fast Loop)
# -----------------------------------------------------------------------------
# Transport mode: "stdio" or "sse"
MCP_TRANSPORT=stdio

# SSE server settings (only used when MCP_TRANSPORT=sse)
MCP_SSE_HOST=0.0.0.0
MCP_SSE_PORT=8080

# Number of top-k similar rules returned by semantic search.
MCP_SEARCH_TOP_K=5

# Minimum cosine similarity score to include a rule in results (0.0 – 1.0).
MCP_SEARCH_MIN_SCORE=0.5

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
